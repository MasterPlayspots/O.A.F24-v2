# Worker Environment Variables
# Copy this file to .dev.vars for local development

# ─── Cloudflare Deployment Credentials ────────────────────────────
# Required for deploying via `wrangler deploy` (local or CI/CD).
# Not needed when using `wrangler login` for interactive authentication.
#
# CLOUDFLARE_ACCOUNT_ID: Found in the Cloudflare Dashboard after selecting your
#   account (visible in the URL and on the Overview page)
# CLOUDFLARE_API_TOKEN: Create at https://dash.cloudflare.com/profile/api-tokens
#   → Use the "Edit Cloudflare Workers" template for required permissions.
#
# For GitHub Actions CI/CD, set these as GitHub Repository Secrets:
#   → Repository Settings > Secrets and variables > Actions > New repository secret
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Authentication
JWT_SECRET=your-jwt-secret-here-min-32-chars
UNLOCK_SECRET=your-unlock-secret-here-min-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Resend Email
RESEND_API_KEY=re_...

# App Configuration
FRONTEND_URL=https://zfbf.info
ENVIRONMENT=development
API_VERSION=v1

# Database & Bindings (configured via wrangler.toml)
# DB: D1 Database
# BAFA_CONTENT: D1 Database
# SESSIONS: KV Namespace
# RATE_LIMIT: KV Namespace
# CACHE: KV Namespace
# WEBHOOK_EVENTS: KV Namespace
# REPORTS: R2 Bucket
# AI: Cloudflare AI Binding
