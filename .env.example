# Fund24 — local environment template
# Copy to .env.local and fill in the secrets you need for local dev.

# ───── Frontend (Next.js) ────────────────────────────────────────────────
NEXT_PUBLIC_FUND24_API_URL=https://api.fund24.io
NEXT_PUBLIC_CHECK_API_URL=https://foerdermittel-check-api.froeba-kevin.workers.dev
NEXT_PUBLIC_SEMANTIC_API_URL=https://api.fund24.io/semantic
NEXT_PUBLIC_ZFBF_API_URL=https://zfbf-api.froeba-kevin.workers.dev

# Required for Next.js middleware JWT verification (server-only on Vercel).
# Must match the JWT_SECRET used by the Cloudflare Worker that signs tokens.
# Vercel: set under Project → Settings → Environment Variables (Production).
JWT_SECRET=your-jwt-secret-min-32-chars

# ───── Sentry ────────────────────────────────────────────────────────────
# DSN is hardcoded in sentry.*.config.ts — only override for staging/dev.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# DSGVO: keep sampling low in prod. 0.1 = 10 % of traces sent.
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ───── Worker (Cloudflare — set via `wrangler secret put`) ───────────────
# SENTRY_DSN
# SENTRY_TRACES_SAMPLE_RATE=0.1
# RESEND_API_KEY
# JWT_SECRET
# STRIPE_SECRET_KEY  (optional, only if payments tested locally)
