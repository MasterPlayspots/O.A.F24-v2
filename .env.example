# Worker Environment Variables
# Copy this file to .dev.vars for local development

# Authentication
JWT_SECRET=your-jwt-secret-here-min-32-chars
UNLOCK_SECRET=your-unlock-secret-here-min-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Resend Email
RESEND_API_KEY=re_...

# App Configuration
FRONTEND_URL=https://zfbf.info
ENVIRONMENT=development
API_VERSION=v1

# Database & Bindings (configured via wrangler.toml)
# DB: D1 Database
# BAFA_CONTENT: D1 Database
# SESSIONS: KV Namespace
# RATE_LIMIT: KV Namespace
# CACHE: KV Namespace
# WEBHOOK_EVENTS: KV Namespace
# REPORTS: R2 Bucket
# AI: Cloudflare AI Binding
