{
  "name": "@bafa/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:cloudflare:* --minify",
    "deploy": "pnpm build && wrangler deploy",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create": "wrangler d1 create zfbf-db",
    "db:migrate": "wrangler d1 execute zfbf-db --remote --file=./db/migrations/schema.sql",
    "db:migrate:local": "wrangler d1 execute zfbf-db --local --file=./db/migrations/schema.sql",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "hono": "^4.7.11",
    "zod": "^4.3.6",
    "@noble/hashes": "^1.6.1",
    "jose": "^5.9.6",
    "@bafa/shared": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250117.0",
    "@cloudflare/vitest-pool-workers": "^0.5.22",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.65.0"
  }
}
