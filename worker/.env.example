# Cloudflare Worker Secrets
# Set via: wrangler secret put <NAME>
# See wrangler.toml for D1/KV/R2 bindings (non-secret)

# Required — JWT signing key (min 32 random chars)
JWT_SECRET=your-jwt-secret-here

# Required — HMAC key for report unlock payment signatures
UNLOCK_SECRET=your-unlock-secret-here

# Required — Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Set after configuring webhook endpoint in Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# Required — PayPal (https://developer.paypal.com/dashboard/applications)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Required — Transactional emails (https://resend.com/api-keys)
RESEND_API_KEY=re_...

# Optional — Error monitoring (https://sentry.io)
SENTRY_DSN=https://...@sentry.io/...
